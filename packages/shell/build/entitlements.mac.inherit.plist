<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Inherited Hardened-Runtime entitlements for Electron helper processes
  (renderer / GPU / utility). Same dict as the parent + inherit so children
  pick up the parent's signing identity rather than each helper being
  signed independently.

  See packages/shell/build/entitlements.mac.plist for the unsigned-exec
  posture explanation.
-->
<plist version="1.0">
<dict>
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.inherit</key>
  <true/>
</dict>
</plist>
