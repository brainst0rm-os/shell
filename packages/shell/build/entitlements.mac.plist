<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Minimal Hardened-Runtime entitlements for the Brainstorm main app bundle.
  Active as of 13.11 (Developer ID signing + notarisation go-live).

  - allow-jit: Electron's V8 needs JIT for any non-trivial JS.
  - allow-unsigned-executable-memory: retained as a safety margin for the
    bundled native .node addon. electron-builder deep-signs nested Mach-O
    (including the .node) under the Developer ID, so this MAY be droppable —
    tighten only after a signed + notarised build is verified to launch.
-->
<plist version="1.0">
<dict>
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
</dict>
</plist>
